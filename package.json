{
  "name": "algo-trading-platform",
  "version": "1.0.0",
  "description": "Unified Algorithmic Trading Platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "python run_backend.py",
    "start:backend": "python run_backend.py",
    "dev": "cd webapp/frontend && npm run dev",
    "dev:frontend": "cd webapp/frontend && npm run dev",
    "dev:all": "concurrently \"npm run start\" \"npm run dev\"",
    "install:backend": "pip install -r webapp/requirements.txt",
    "install:frontend": "cd webapp/frontend && npm install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "zerodha:login": "python scripts/login_zerodha.py",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "trading",
    "algorithmic-trading",
    "quantitative-trading",
    "stock-market",
    "api",
    "zerodha",
    "kite-connect"
  ],
  "author": "Quantitative Trading Systems Engineer",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
