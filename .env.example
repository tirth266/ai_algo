# ============================================================================
# ALGORITHMIC TRADING PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and configure for your environment
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
POSTGRES_DB=algo_trading
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword123
DB_PORT=5432

# Database URL (auto-constructed from above, override if needed)
# DATABASE_URL=postgresql://postgres:securepassword123@localhost:5432/algo_trading

# ----------------------------------------------------------------------------
# REDIS CACHE CONFIGURATION
# ----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ----------------------------------------------------------------------------
# ZERODHA BROKER CONFIGURATION
# ----------------------------------------------------------------------------
ZERODHA_API_KEY=your_api_key_here
ZERODHA_API_SECRET=your_api_secret_here
ZERODHA_USER_ID=your_user_id_here
ZERODHA_PASSWORD=your_password_here
ZERODHA_TOTP_SECRET=your_totp_secret_here
ZERODHA_PRODUCT_TYPE=MIS
ZERODHA_EXCHANGE=NSE

# ----------------------------------------------------------------------------
# TRADING CONFIGURATION
# ----------------------------------------------------------------------------
TRADING_MODE=paper  # paper or live
MAX_RISK_PER_TRADE=0.02  # 2% of capital per trade
MAX_DAILY_LOSS=0.05      # 5% daily loss limit
MAX_OPEN_POSITIONS=5
MAX_TRADES_PER_DAY=20
CAPITAL_PER_TRADE=50000  # INR

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3000
HOST=0.0.0.0
DEBUG=false

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=logs/trading.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ----------------------------------------------------------------------------
# STRATEGY CONFIGURATION
# ----------------------------------------------------------------------------
DEFAULT_STRATEGIES=LuxAlgoTrendlineStrategy
STRATEGY_RUN_INTERVAL=300  # seconds
MARKET_DATA_TIMEFRAME=5m

# ----------------------------------------------------------------------------
# RISK MANAGEMENT
# ----------------------------------------------------------------------------
STOP_LOSS_PERCENTAGE=2.0
TARGET_PERCENTAGE=4.0
TRAILING_STOP_LOSS=true
MAX_PORTFOLIO_RISK=0.10

# ----------------------------------------------------------------------------
# MARKET DATA
# ----------------------------------------------------------------------------
DATA_SOURCE=zerodha  # zerodha, yahoo, mock
CANDLE_LOOKBACK=500
CACHE_TTL_SECONDS=30

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
SECRET_KEY=your-secret-key-change-this-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# ----------------------------------------------------------------------------
# MONITORING & ALERTS
# ----------------------------------------------------------------------------
ENABLE_ALERTS=false
ALERT_EMAIL=your_email@example.com
ALERT_WEBHOOK_URL=

# ----------------------------------------------------------------------------
# PERFORMANCE
# ----------------------------------------------------------------------------
WORKERS=4
THREADS=2
WORKER_TIMEOUT=120
KEEP_ALIVE=5

# ============================================================================
# ANGEL ONE SETUP INSTRUCTIONS:
# 1. ANGEL_ONE_API_KEY & ANGEL_ONE_SECRET_KEY:
#    → Go to https://smartapi.angelbroking.com/
#    → Login → My Profile → API Key section
#
# 2. ANGEL_ONE_CLIENT_ID:
#    → This is your Angel One trading account login ID (e.g. A123456)
#    → Found on your Angel One app → Profile
#
# 3. ANGEL_ONE_TOTP_SEED:
#    → Go to Angel One app → Profile → Enable TOTP
#    → When shown the QR code, click "Can't scan?" to get the text seed
#    → Copy the base32 secret string (looks like: JBSWY3DPEHPK3PXP)
#    → Paste it here - this allows automated 2FA login
#
# 4. REDIRECT URL for Add App form:
#    → Deploy frontend to Vercel (free)
#    → Use: https://YOUR-APP.vercel.app/angel-callback
#    → Localhost will NOT work for Angel One redirect URL
# ============================================================================
